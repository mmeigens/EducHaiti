{
  "expo": {
    "name": "EduHaïti",
    "slug": "edu-haiti",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1C1152"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.eduhaiti.sgs"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1C1152"
      },
      "package": "com.eduhaiti.sgs",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
